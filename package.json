{
  "name": "rix",
  "version": "0.1.0",
  "description": "RiX, the Rational Interval Expression Language",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./parser": "./src/parser/index.js",
    "./eval": "./src/eval/index.js",
    "./runtime": "./src/runtime/index.js"
  },
  "bin": {
    "rix": "./bin/rix.js",
    "rix-to-ir": "./bin/rix-to-ir.js"
  },
  "scripts": {
    "test": "bun test",
    "test:parser": "bun test tests/parser",
    "test:eval": "bun test tests/eval",
    "test:tools": "bun test tests/tools",
    "build:demo": "bun build ./documentation/parser/src/demo.js --outfile ./documentation/parser/demo.js --target browser",
    "docs:reference": "bun ./documentation/scripts/generate-reference.js",
    "docs:check": "bun run docs:reference && bun ./documentation/scripts/run-quarto.js render",
    "build:docs": "bun run build:demo && bun run docs:reference && bun ./documentation/scripts/run-quarto.js render",
    "preview:docs": "bun run build:demo && bun run docs:reference && bun ./documentation/scripts/run-quarto.js preview",
    "build:all": "bun run build:docs"
  },
  "dependencies": {
    "@ratmath/core": "workspace:*"
  },
  "devDependencies": {
    "marked": "^15.0.12"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "license": "MIT"
}

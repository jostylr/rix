    LN = [{= name = :Float, prep = (x) -> x ? :float, impl = (x) -> .JSCall("floats.js", :Ln, x) }],
    LOG10 = [{= name = :Float, prep = (x) -> x ? :float, impl = (x) -> .JSCall("floats.js", :Log10, x) }],
    EXP = [{= name = :Float, prep = (x) -> x ? :float, impl = (x) -> .JSCall("floats.js", :Exp, x) }]
